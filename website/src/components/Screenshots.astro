---
import { SCREENSHOTS } from '@/consts';
import Container from './Container.astro';
---

<section class="py-20 md:py-28 bg-[#f4f4f7]">
  <Container>
    <div class="max-w-2xl mb-12">
      <p class="text-sm font-semibold text-[#6200ee] mb-3 uppercase tracking-wider">Screenshots</p>
      <h2 class="text-3xl md:text-4xl font-bold mb-4">See NoteNext in motion.</h2>
      <p class="text-lg text-[#6b7280]">
        Material 3 Expressive design across every surface — from the notes grid to the privacy controls.
      </p>
    </div>

    <div class="overflow-x-auto -mx-5 px-5 sm:-mx-6 sm:px-6 lg:-mx-8 lg:px-8 pb-4 [scrollbar-width:thin]">
      <ul class="flex gap-5 snap-x snap-mandatory">
        {
          SCREENSHOTS.map((shot) => (
            <li class="snap-start flex-shrink-0 w-[260px] md:w-[300px]">
              <div class="relative aspect-[9/19.5] rounded-[2.25rem] border-[10px] border-[#0b0b0d] bg-[#0b0b0d] shadow-2xl overflow-hidden">
                <img
                  src={shot.src}
                  alt={shot.alt}
                  loading="lazy"
                  decoding="async"
                  width="300"
                  height="650"
                  class="w-full h-full object-cover object-top"
                />
              </div>
              <p class="text-sm text-[#6b7280] mt-4 text-center px-2">{shot.caption}</p>
            </li>
          ))
        }
      </ul>
    </div>
  </Container>
</section>
