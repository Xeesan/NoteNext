---
import Icon from './Icon.astro';

interface Props {
  icon: string;
  title: string;
  description: string;
  accent?: 'brand' | 'accent' | 'pink' | 'amber';
}

const { icon, title, description, accent = 'brand' } = Astro.props;

const accentColors: Record<string, string> = {
  brand: 'bg-[#6200ee]/10 text-[#6200ee]',
  accent: 'bg-[#00c853]/10 text-[#00964c]',
  pink: 'bg-pink-50 text-pink-700',
  amber: 'bg-amber-50 text-amber-700',
};
---

<article class="card p-6">
  <div class={`w-11 h-11 rounded-xl flex items-center justify-center mb-4 ${accentColors[accent]}`}>
    <Icon name={icon} size={22} />
  </div>
  <h3 class="font-semibold text-lg mb-2">{title}</h3>
  <p class="text-sm text-[#6b7280] leading-relaxed">{description}</p>
</article>
