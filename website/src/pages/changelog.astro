---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Container from '@/components/Container.astro';
import changelog from '../../../changelog.json';
import { SITE } from '@/consts';

interface ChangeItem {
  title: string;
  description: string;
  type: 'FEATURE' | 'IMPROVEMENT' | 'FIX' | 'UI' | string;
}

interface Release {
  version: string;
  date: string;
  items: ChangeItem[];
}

const releases = (changelog.releases as Release[]) || [];

const toIsoDate = (d: string): string => {
  const parsed = new Date(`${d} UTC`);
  if (isNaN(parsed.getTime())) return d;
  const y = parsed.getUTCFullYear();
  const m = String(parsed.getUTCMonth() + 1).padStart(2, '0');
  const day = String(parsed.getUTCDate()).padStart(2, '0');
  return `${y}-${m}-${day}`;
};

const changelogUrl = new URL('/changelog/', SITE.url).toString();

const changelogSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: `${SITE.name} release history`,
  description: `Release notes and changelog for ${SITE.name} Android app.`,
  numberOfItems: releases.length,
  itemListOrder: 'https://schema.org/ItemListOrderDescending',
  itemListElement: releases.map((release, idx) => ({
    '@type': 'ListItem',
    position: idx + 1,
    item: {
      '@type': 'TechArticle',
      headline: `${SITE.name} v${release.version}`,
      name: `${SITE.name} v${release.version}`,
      url: `${changelogUrl}#v${release.version}`,
      datePublished: toIsoDate(release.date),
      inLanguage: 'en',
      articleSection: 'Release Notes',
      author: {
        '@type': 'Person',
        name: SITE.author,
        url: SITE.authorUrl,
      },
      publisher: {
        '@type': 'Person',
        name: SITE.author,
        url: SITE.authorUrl,
      },
      about: {
        '@type': 'SoftwareApplication',
        name: SITE.name,
        operatingSystem: 'Android',
        applicationCategory: 'ProductivityApplication',
        softwareVersion: release.version,
      },
      articleBody: release.items
        .map((item) => `${item.type}: ${item.title}. ${item.description}`)
        .join(' \n'),
    },
  })),
};

const typeStyles: Record<string, string> = {
  FEATURE: 'bg-[#6200ee]/10 text-[#6200ee]',
  IMPROVEMENT: 'bg-[#00c853]/15 text-[#00964c]',
  FIX: 'bg-amber-100 text-amber-800',
  UI: 'bg-pink-100 text-pink-700',
};

const typeLabel: Record<string, string> = {
  FEATURE: 'New',
  IMPROVEMENT: 'Improved',
  FIX: 'Fix',
  UI: 'UI',
};
---

<BaseLayout
  title="Changelog"
  description="Release history of NoteNext — every new feature, improvement, and fix since launch."
  pageTitle="Changelog"
>
  <section class="mesh-bg pt-20 pb-14">
    <Container size="narrow" class="text-center">
      <p class="text-sm font-semibold text-[#6200ee] mb-3 uppercase tracking-wider">Changelog</p>
      <h1 class="text-4xl md:text-5xl font-extrabold mb-5">What's new in NoteNext</h1>
      <p class="text-lg text-[#6b7280]">
        Every release, in chronological order. Subscribe to GitHub releases to be the first to know.
      </p>
    </Container>
  </section>

  <section class="py-14">
    <Container size="narrow">
      <div class="space-y-12">
        {
          releases.map((release, idx) => (
            <article id={`v${release.version}`} class="relative pl-8 md:pl-0 md:grid md:grid-cols-[180px_1fr] md:gap-10">
              <div class="md:sticky md:top-24 md:self-start mb-4 md:mb-0">
                <div class="absolute left-0 top-1.5 md:hidden w-3 h-3 rounded-full bg-[#6200ee]"></div>
                <p class="text-2xl font-extrabold tracking-tight">v{release.version}</p>
                <p class="text-sm text-[#6b7280] mt-1">{release.date}</p>
                {idx === 0 && (
                  <span class="inline-block mt-2 px-2 py-0.5 rounded-full bg-[#00c853]/15 text-[#00964c] text-[11px] font-semibold">
                    Latest
                  </span>
                )}
              </div>

              <div class="card p-6 md:p-7">
                <ul class="space-y-5">
                  {release.items.map((item) => (
                    <li>
                      <div class="flex items-start gap-3 flex-wrap">
                        <span class={`text-[10px] font-bold px-2 py-0.5 rounded-full uppercase tracking-wide flex-shrink-0 ${typeStyles[item.type] ?? 'bg-[#f4f4f7] text-[#6b7280]'}`}>
                          {typeLabel[item.type] ?? item.type}
                        </span>
                        <h3 class="font-semibold flex-1 min-w-0">{item.title}</h3>
                      </div>
                      <p class="text-sm text-[#6b7280] mt-2 ml-0 leading-relaxed">{item.description}</p>
                    </li>
                  ))}
                </ul>
              </div>
            </article>
          ))
        }
      </div>

      {releases.length === 0 && (
        <p class="text-center text-[#6b7280] py-10">Changelog is being prepared.</p>
      )}

      {releases.length > 0 && (
        <script
          type="application/ld+json"
          set:html={JSON.stringify(changelogSchema)}
        />
      )}
    </Container>
  </section>
</BaseLayout>
