---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Container from '@/components/Container.astro';
import Icon from '@/components/Icon.astro';
import { SITE } from '@/consts';
---

<BaseLayout
  title="Contact"
  description="Get in touch about NoteNext — feedback, feature requests, security disclosures, partnerships."
  pageTitle="Contact"
>
  <section class="mesh-bg pt-20 pb-14">
    <Container size="narrow" class="text-center">
      <p class="text-sm font-semibold text-[#6200ee] mb-3 uppercase tracking-wider">Contact</p>
      <h1 class="text-4xl md:text-5xl font-extrabold mb-5">Let's talk.</h1>
      <p class="text-lg text-[#6b7280]">
        Bug reports, feature ideas, partnerships, or just hello — pick whichever channel fits.
      </p>
    </Container>
  </section>

  <section class="py-14 border-b border-[#e5e7eb]">
    <Container size="narrow">
      <div class="card p-8 md:p-10 relative overflow-hidden">
        <!-- Contact Form -->
        <div id="form-container">
          <h2 class="text-2xl font-bold mb-6">Send a message</h2>
          <form id="contact-form" class="space-y-5">
            <div class="grid sm:grid-cols-2 gap-5">
              <div class="space-y-2">
                <label for="name" class="text-sm font-semibold text-[#374151]">Name</label>
                <input 
                  type="text" 
                  id="name" 
                  name="name" 
                  required 
                  placeholder="John Doe"
                  class="w-full px-4 py-3 rounded-xl border border-[#e5e7eb] focus:ring-2 focus:ring-[#6200ee] focus:border-transparent outline-none transition-all"
                />
              </div>
              <div class="space-y-2">
                <label for="email" class="text-sm font-semibold text-[#374151]">Email</label>
                <input 
                  type="email" 
                  id="email" 
                  name="email" 
                  required 
                  placeholder="john@example.com"
                  class="w-full px-4 py-3 rounded-xl border border-[#e5e7eb] focus:ring-2 focus:ring-[#6200ee] focus:border-transparent outline-none transition-all"
                />
              </div>
            </div>
            <div class="space-y-2">
              <label for="subject" class="text-sm font-semibold text-[#374151]">Subject</label>
              <input 
                type="text" 
                id="subject" 
                name="subject" 
                placeholder="Feedback / Feature Request"
                class="w-full px-4 py-3 rounded-xl border border-[#e5e7eb] focus:ring-2 focus:ring-[#6200ee] focus:border-transparent outline-none transition-all"
              />
            </div>
            <div class="space-y-2">
              <label for="message" class="text-sm font-semibold text-[#374151]">Message</label>
              <textarea 
                id="message" 
                name="message" 
                required 
                rows="5" 
                placeholder="Tell us more..."
                class="w-full px-4 py-3 rounded-xl border border-[#e5e7eb] focus:ring-2 focus:ring-[#6200ee] focus:border-transparent outline-none transition-all resize-none"
              ></textarea>
            </div>
            <button type="submit" id="submit-btn" class="btn btn-primary w-full sm:w-auto">
              <span>Send Message</span>
              <Icon name="arrowRight" size={18} />
            </button>
            <div id="error-status" class="hidden text-sm font-semibold p-4 rounded-xl bg-red-100 text-red-700 mt-4"></div>
          </form>
        </div>

        <!-- Success State (Hidden by default) -->
        <div id="success-container" class="hidden py-12 text-center animate-in fade-in zoom-in duration-500">
          <div class="w-20 h-20 rounded-full bg-green-100 text-green-600 flex items-center justify-center mx-auto mb-6">
            <Icon name="check" size={40} />
          </div>
          <h2 class="text-3xl font-bold mb-3">Message sent!</h2>
          <p class="text-lg text-[#6b7280] mb-8 max-w-md mx-auto">
            Thanks for reaching out. Your message is on its way to the maker.
          </p>
          <div class="bg-[#f4f4f7] rounded-2xl p-6 mb-8 max-w-sm mx-auto border border-[#e5e7eb]">
            <p class="text-sm font-semibold text-[#374151] mb-1 uppercase tracking-tight">Expected Reply</p>
            <p class="text-[#6200ee] font-bold text-lg">Within 24 hours</p>
            <p class="text-xs text-[#6b7280] mt-2">Check your inbox (and spam folder) for a response.</p>
          </div>
          <button id="reset-btn" class="btn btn-secondary">
            Send another message
          </button>
        </div>
      </div>
    </Container>
  </section>

  <section class="py-14">
    <Container size="narrow">
      <div class="grid sm:grid-cols-2 gap-5">
        <a href={`mailto:${SITE.email}`} class="card p-7">
          <div class="w-12 h-12 rounded-xl bg-[#6200ee]/10 text-[#6200ee] flex items-center justify-center mb-4">
            <Icon name="share" size={22} />
          </div>
          <h2 class="text-lg font-bold mb-1">Email</h2>
          <p class="text-sm text-[#6b7280] mb-3">For everything else — usually replied within a day.</p>
          <span class="text-sm font-semibold text-[#6200ee] break-all">{SITE.email}</span>
        </a>

        <a href={`${SITE.github}/issues/new`} target="_blank" rel="noopener" class="card p-7">
          <div class="w-12 h-12 rounded-xl bg-[#0b0b0d] text-white flex items-center justify-center mb-4">
            <Icon name="github" size={22} />
          </div>
          <h2 class="text-lg font-bold mb-1">GitHub Issues</h2>
          <p class="text-sm text-[#6b7280] mb-3">Bug reports, feature requests, public discussion.</p>
          <span class="text-sm font-semibold text-[#6200ee]">Open an issue →</span>
        </a>

        <div class="card p-7">
          <div class="w-12 h-12 rounded-xl bg-amber-100 text-amber-700 flex items-center justify-center mb-4">
            <Icon name="shield" size={22} />
          </div>
          <h2 class="text-lg font-bold mb-1">Security disclosures</h2>
          <p class="text-sm text-[#6b7280] mb-3">
            Found a vulnerability? Email privately — please don't file a public issue.
          </p>
          <a href={`mailto:${SITE.email}?subject=Security%20Disclosure`} class="text-sm font-semibold text-[#6200ee]">
            Email support@ →
          </a>
        </div>

        <a href={SITE.authorUrl} target="_blank" rel="noopener" class="card p-7">
          <div class="w-12 h-12 rounded-xl bg-pink-100 text-pink-700 flex items-center justify-center mb-4">
            <Icon name="sparkle" size={22} />
          </div>
          <h2 class="text-lg font-bold mb-1">About the maker</h2>
          <p class="text-sm text-[#6b7280] mb-3">
            NoteNext is built by Suvojeet Sengupta — see other projects.
          </p>
          <span class="text-sm font-semibold text-[#6200ee]">suvojeetsengupta.in →</span>
        </a>
      </div>
    </Container>
  </section>
</BaseLayout>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const formContainer = document.getElementById('form-container');
  const successContainer = document.getElementById('success-container');
  const errorStatus = document.getElementById('error-status');
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
  const resetBtn = document.getElementById('reset-btn');

  if (form && formContainer && successContainer && errorStatus && submitBtn) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      
      const formData = new FormData(form);
      const payload = {
        name: formData.get('name'),
        email: formData.get('email'),
        subject: formData.get('subject') || 'Contact from Notenext',
        message: formData.get('message'),
        type: 'Notenext'
      };

      // Reset error status
      errorStatus.classList.add('hidden');
      errorStatus.textContent = '';
      
      submitBtn.disabled = true;
      submitBtn.style.opacity = '0.7';
      const originalBtnText = submitBtn.innerHTML;
      submitBtn.innerHTML = '<span>Sending...</span>';

      try {
        const response = await fetch('https://suvojeetsengupta.in/api/public/contact', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
          },
          body: JSON.stringify(payload),
        });

        const result = await response.json();

        if (result.success) {
          // Show beautiful success screen
          formContainer.classList.add('hidden');
          successContainer.classList.remove('hidden');
          form.reset();
        } else {
          errorStatus.textContent = 'Error: ' + (result.error || 'Something went wrong.');
          errorStatus.classList.remove('hidden');
        }
      } catch (error) {
        errorStatus.textContent = 'Network error. Please try again later.';
        errorStatus.classList.remove('hidden');
      } finally {
        submitBtn.disabled = false;
        submitBtn.style.opacity = '1';
        submitBtn.innerHTML = originalBtnText;
      }
    });
  }

  if (resetBtn && formContainer && successContainer) {
    resetBtn.addEventListener('click', () => {
      successContainer.classList.add('hidden');
      formContainer.classList.remove('hidden');
    });
  }
</script>
