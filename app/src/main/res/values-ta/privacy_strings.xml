    <string name="priv_self_destruct_title">சுய அழிவு குறிப்புகள்</string>
    <string name="priv_self_destruct_subtitle">ஒரு குறிப்பிட்ட நேரத்திற்குப் பிறகு குறிப்புகள் தானாக நீக்கப்பட அமைக்கவும்</string>
    <string name="priv_self_destruct_message">சுய அழிவு என்பது ஒவ்வொரு குறிப்புக்கான அம்சம். ஒரு குறிப்பைத் திருத்தும்போது \'மேலும்\' (மூன்று-புள்ளி) மெனுவைக் கிளிக் செய்து \'Self-Destruct Timer\' தேர்ந்தெடுப்பதன் மூலம் எந்த குறிப்புக்கும் டைமரை அமைக்கலாம். டைமர் காலாவதியானதும், குறிப்பு நிரந்தரமாக நீக்கப்படும்.</string>

    <string name="priv_decoy_dialog_title">டிகாய் PIN-ஐ அமை</string>
    <string name="priv_decoy_dialog_message">4-இலக்க இரண்டாம் PIN-ஐ உள்ளிடவும். பூட்டுத் திரையில் இந்த PIN-ஐ உள்ளிடுவது தனி, டிகாய் வால்ட்டைத் திறக்கும்.</string>
    <string name="priv_decoy_pin_label">இரண்டாம் PIN</string>
    <string name="priv_decoy_pin_confirm_label">இரண்டாம் PIN-ஐ உறுதிப்படுத்து</string>
    <string name="priv_err_pin_length">PIN 4 இலக்கங்கள் இருக்க வேண்டும்</string>
    <string name="priv_err_pin_mismatch">PIN-கள் பொருந்தவில்லை</string>
    <string name="priv_err_pin_clash">டிகாய் PIN உங்கள் ஆப் PIN-இலிருந்து வேறுபட வேண்டும்</string>
